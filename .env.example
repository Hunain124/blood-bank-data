# =============================================
# KARACHI BLOOD BANK FINDER - ENV CONFIG
# =============================================
# Copy this file to .env and fill in your values
# Never commit .env to GitHub!

# --- Supabase ---
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- Server ---
PORT=3000
NODE_ENV=production

# --- Security ---
# A random secret string for admin routes (make something long & random)
ADMIN_SECRET=change-this-to-something-random-and-long

# --- CORS ---
# Your frontend URL (where your HTML file is hosted)
FRONTEND_URL=https://your-frontend-domain.com
